---
interface Props {
  title: string;
  subtitle?: string;
  centered?: boolean;
}

const { title, subtitle, centered = false } = Astro.props;
---

<div class={centered ? 'text-center' : ''}>
  <h2 class="text-3xl font-bold text-text md:text-4xl">{title}</h2>
  <div class={`mt-3 h-1 w-16 rounded-full bg-accent ${centered ? 'mx-auto' : ''}`}></div>
  {subtitle && <p class="mt-4 text-base leading-relaxed text-text/60 md:text-lg">{subtitle}</p>}
</div>

---
interface Props {
  title: string;
  description: string;
  badge?: string;
  icon: string;
}

const { title, description, badge, icon } = Astro.props;
---

<article class="rounded-card bg-white p-6 shadow-sm transition-shadow hover:shadow-md">
  <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-accent/10">
    <span class="text-2xl">{icon}</span>
  </div>
  <h3 class="mb-2 text-lg font-bold text-text">{title}</h3>
  <p class="text-sm leading-relaxed text-text/60">{description}</p>
  {badge && <div class="mt-4"><span class="inline-block rounded-full bg-accent/10 px-3 py-1 text-xs font-semibold text-accent">{badge}</span></div>}
</article>

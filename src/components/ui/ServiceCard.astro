---
interface Props {
  title: string;
  description: string;
  badge?: string;
  icon: string;
}
const { title, description, badge, icon } = Astro.props;
---

<article class="service-card">
  <div class="service-card__icon" set:html={icon} />
  <h3>{title}</h3>
  <p>{description}</p>
  {badge && <span class="service-card__badge">{badge}</span>}
</article>

<style>
  .service-card {
    background: white;
    border-radius: var(--radius-card);
    padding: 1.5rem;
    box-shadow: var(--shadow-sm);
    transition: box-shadow 0.25s var(--ease-out-quint), transform 0.25s var(--ease-out-quint);
  }
  .service-card:hover { box-shadow: var(--shadow-md); transform: translateY(-3px); }

  .service-card__icon {
    width: 3rem;
    height: 3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
    background-color: var(--color-accent-10);
    margin-bottom: 1rem;
    flex-shrink: 0;
  }
  .service-card__icon svg {
    width: 1.375rem;
    height: 1.375rem;
    stroke: var(--color-accent);
  }
  .service-card h3 {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }
  .service-card p {
    font-size: 0.875rem;
    line-height: 1.625;
    color: var(--color-text-60);
  }
  .service-card__badge {
    display: inline-block;
    margin-top: 1rem;
    border-radius: 9999px;
    background-color: var(--color-accent-10);
    color: var(--color-accent);
    padding: 0.25rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 600;
  }
</style>

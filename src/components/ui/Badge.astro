---
interface Props {
  text: string;
  color?: 'primary' | 'accent';
}

const { text, color = 'accent' } = Astro.props;

const colors = {
  primary: 'bg-primary/10 text-primary',
  accent: 'bg-accent/10 text-accent',
};
---

<span class={`inline-block rounded-full px-3 py-1 text-xs font-semibold ${colors[color]}`}>
  {text}
</span>

---
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionTitle from '@components/ui/SectionTitle.astro';
import Badge from '@components/ui/Badge.astro';
import { Image } from 'astro:assets';
import fotoPlaceholder from '../assets/placeholder-foto.svg';

const valores = [
  {
    icon: '👂',
    title: 'Escucha activa',
    description:
      'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Cada paciente tiene una historia única que merece ser escuchada.',
  },
  {
    icon: '🎯',
    title: 'Tratamiento personalizado',
    description:
      'Lorem ipsum dolor sit amet, consectetur adipiscing elit. No existen protocolos genéricos, solo planes adaptados a ti.',
  },
  {
    icon: '🔬',
    title: 'Evidencia científica',
    description:
      'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Técnicas respaldadas por la investigación y la práctica clínica.',
  },
];

const titulaciones = [
  'Graduada en Fisioterapia — Universidad Complutense de Madrid',
  'Máster en Fisioterapia Deportiva — UCAM Murcia',
  'Especialista en Fisioterapia Neurológica — Bobath',
  'Certificada en Pilates Terapéutico — Stott Pilates',
  'Colegiada por el Colegio Profesional de Fisioterapeutas de Madrid — Nº 12345',
];
---

<BaseLayout
  title="Quién soy"
  description="Conoce a Raquel Martínez, fisioterapeuta colegiada en Madrid. Formación, experiencia y filosofía de tratamiento."
>
  <!-- Hero de página -->
  <section class="bg-primary/5 py-16">
    <div class="mx-auto max-w-6xl px-6">
      <p class="mb-2 text-sm text-text/40">
        <a href="/" class="hover:text-primary">Inicio</a> / Quién soy
      </p>
      <h1 class="text-4xl font-bold text-primary md:text-5xl">Quién soy</h1>
    </div>
  </section>

  <!-- Bio principal -->
  <section class="mx-auto max-w-6xl px-6 py-20">
    <div class="grid items-start gap-12 md:grid-cols-2">
      <div class="flex justify-center md:justify-start">
        <div class="overflow-hidden rounded-2xl shadow-lg">
          <Image
            src={fotoPlaceholder}
            alt="Raquel Martínez García, fisioterapeuta"
            width={340}
            height={450}
            class="h-auto w-72 md:w-80"
          />
        </div>
      </div>
      <div>
        <Badge text="Fisioterapeuta Colegiada Nº 12345" color="primary" />
        <h2 class="mt-4 text-3xl font-bold text-text md:text-4xl">Raquel Martínez García</h2>
        <div class="mt-2 h-1 w-16 rounded-full bg-accent"></div>

        <p class="mt-6 leading-relaxed text-text/70">
          Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor
          incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud
          exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat duis aute irure
          dolor in reprehenderit.
        </p>
        <p class="mt-4 leading-relaxed text-text/70">
          Sed ut perspiciatis unde omnis iste natus error sit voluptatem accusantium doloremque
          laudantium, totam rem aperiam, eaque ipsa quae ab illo inventore veritatis et quasi
          architecto beatae vitae dicta sunt explicabo nemo enim ipsam voluptatem.
        </p>
        <p class="mt-4 leading-relaxed text-text/70">
          Nemo enim ipsam voluptatem quia voluptas sit aspernatur aut odit aut fugit, sed quia
          consequuntur magni dolores eos qui ratione voluptatem sequi nesciunt neque porro
          quisquam est, qui dolorem ipsum quia dolor sit amet.
        </p>

        <!-- Titulaciones -->
        <div class="mt-8">
          <p class="mb-3 text-sm font-semibold uppercase tracking-wider text-text/40">Formación</p>
          <ul class="space-y-2">
            {
              titulaciones.map((t) => (
                <li class="flex items-start gap-2 text-sm text-text/70">
                  <span class="mt-0.5 text-accent">✓</span>
                  {t}
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Valores -->
  <section class="bg-primary/5 py-20">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mb-12 text-center">
        <SectionTitle
          title="Mi filosofía de trabajo"
          subtitle="Lorem ipsum dolor sit amet, consectetur adipiscing elit. Tres pilares guían cada tratamiento."
          centered
        />
      </div>
      <div class="grid gap-6 md:grid-cols-3">
        {
          valores.map(({ icon, title, description }) => (
            <div class="rounded-card bg-white p-8 shadow-sm">
              <div class="mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-accent/10 text-3xl">
                {icon}
              </div>
              <h3 class="mb-3 text-xl font-bold text-text">{title}</h3>
              <p class="text-sm leading-relaxed text-text/60">{description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-primary py-20">
    <div class="mx-auto max-w-3xl px-6 text-center text-white">
      <h2 class="text-3xl font-bold md:text-4xl">¿Empezamos juntos?</h2>
      <p class="mt-4 text-lg text-white/75">
        Lorem ipsum dolor sit amet, consectetur adipiscing elit. Ponte en contacto y te cuento cómo puedo ayudarte.
      </p>
      <div class="mt-8">
        <a
          href="/contacto"
          class="inline-flex items-center justify-center rounded-btn bg-white px-10 py-4 text-base font-bold text-primary transition-colors hover:bg-white/90"
        >
          Reservar primera cita
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

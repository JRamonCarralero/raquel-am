---
import BaseLayout from '@layouts/BaseLayout.astro';
import Button from '@components/ui/Button.astro';
import SectionTitle from '@components/ui/SectionTitle.astro';
import ServiceCard from '@components/ui/ServiceCard.astro';
import Badge from '@components/ui/Badge.astro';
import { Image } from 'astro:assets';
import fotoPlaceholder from '../assets/placeholder-foto.svg';

const svgHand = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 11V6a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v0"/><path d="M14 10V4a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v2"/><path d="M10 10.5V6a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v8"/><path d="M18 8a2 2 0 1 1 4 0v6a8 8 0 0 1-8 8h-2c-2.8 0-4.5-.86-5.99-2.34l-3.6-3.6a2 2 0 0 1 2.83-2.82L7 15"/></svg>`;
const svgZap = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`;
const svgLeaf = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>`;
const svgCpu = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><path d="M15 2v2M15 20v2M9 2v2M9 20v2M2 15h2M20 15h2M2 9h2M20 9h2"/></svg>`;
const svgMessage = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg>`;
const svgTarget = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>`;
const svgShield = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>`;
const svgMapPin = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>`;
const svgPhone = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.7 12.15a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.61 1.5h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.18 6.18l1.27-.94a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>`;
const svgMail = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>`;
const svgWhatsApp = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>`;
const svgInstagram = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>`;

const services = [
  {
    icon: svgHand,
    title: 'Fisioterapia Manual',
    description: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Técnicas manuales para aliviar el dolor y recuperar la movilidad articular.',
    badge: 'Más solicitado',
  },
  {
    icon: svgZap,
    title: 'Fisioterapia Deportiva',
    description: 'Tratamiento y prevención de lesiones deportivas. Lorem ipsum dolor sit amet, consectetur adipiscing elit ut aliquam.',
    badge: 'Deportistas',
  },
  {
    icon: svgLeaf,
    title: 'Pilates Terapéutico',
    description: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Ejercicio terapéutico para mejorar la postura y el control motor.',
    badge: 'Grupal / Individual',
  },
  {
    icon: svgCpu,
    title: 'Neurorehabilitación',
    description: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Recuperación funcional tras lesiones neurológicas.',
    badge: 'Especializado',
  },
];

const valores = [
  {
    icon: svgMessage,
    title: 'Escucha activa',
    description: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Cada paciente tiene una historia única que merece ser escuchada.',
  },
  {
    icon: svgTarget,
    title: 'Tratamiento personalizado',
    description: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. No existen protocolos genéricos, solo planes adaptados a ti.',
  },
  {
    icon: svgShield,
    title: 'Evidencia científica',
    description: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Técnicas respaldadas por la investigación y la práctica clínica.',
  },
];

const titulaciones = [
  'Graduada en Fisioterapia — Universidad Complutense de Madrid',
  'Máster en Fisioterapia Deportiva — UCAM Murcia',
  'Especialista en Fisioterapia Neurológica — Bobath',
  'Certificada en Pilates Terapéutico — Stott Pilates',
  'Colegiada por el Colegio Profesional de Fisioterapeutas de Madrid — Nº 12345',
];

const contactInfo = [
  { icon: svgMapPin,  label: 'Dirección', value: 'Calle del Bienestar, 42, 2ºB\n28001 Madrid', href: null },
  { icon: svgPhone,   label: 'Teléfono',  value: '+34 912 345 678',             href: 'tel:+34912345678' },
  { icon: svgMail,    label: 'Email',      value: 'hola@raquel-fisioterapia.es', href: 'mailto:hola@raquel-fisioterapia.es' },
];

const horario = [
  { dia: 'Lunes – Viernes', horas: '9:00 – 20:00' },
  { dia: 'Sábados',         horas: '10:00 – 14:00' },
  { dia: 'Domingos',        horas: 'Cerrado' },
];
---

<BaseLayout
  title="Fisioterapia en Madrid"
  description="Raquel Alonso Martínez, fisioterapeuta en Madrid. Tratamientos personalizados de fisioterapia manual, deportiva, pilates terapéutico y neurorehabilitación."
>

  <!-- ── INICIO ────────────────────────────────────────────── -->
  <section id="inicio" class="hero">
    <div class="hero__inner">
      <div class="hero__content">
        <p class="hero__pill">Fisioterapia · Madrid</p>
        <h1 class="hero__title">Tu bienestar,<br />en buenas manos</h1>
        <p class="hero__desc">
          Lorem ipsum dolor sit amet, consectetur adipiscing elit. Ut enim ad minim veniam,
          quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat.
        </p>
        <div class="hero__cta">
          <a href="#servicios" class="hero__btn hero__btn--outline">Ver servicios</a>
          <a href="#contacto"  class="hero__btn hero__btn--solid">Contacto</a>
        </div>
      </div>
      <div class="hero__img-wrap">
        <Image
          src={fotoPlaceholder}
          alt="Raquel Alonso Martínez, fisioterapeuta"
          width={300}
          height={400}
          class="hero__img"
        />
      </div>
    </div>
    <div class="hero__wave" aria-hidden="true">
      <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0 60L1440 60L1440 20C1200 60 960 0 720 20C480 40 240 0 0 20Z" fill="#F8F9FA"/>
      </svg>
    </div>
  </section>

  <!-- ── SERVICIOS ─────────────────────────────────────────── -->
  <section id="servicios" class="section">
    <div class="container">
      <div class="section__header">
        <SectionTitle
          title="Nuestros Servicios"
          subtitle="Un enfoque integral para cada paciente, combinando las técnicas más avanzadas con un trato cercano y personalizado."
          centered
        />
      </div>
      <div class="services-grid" data-reveal-stagger>
        {services.map((s) => <ServiceCard {...s} />)}
      </div>
    </div>
  </section>

  <!-- ── QUIÉN SOY ─────────────────────────────────────────── -->
  <section id="quien-soy" class="section section--white">
    <div class="container">
      <div class="bio-grid" data-reveal>
        <div class="bio__img-wrap">
          <Image
            src={fotoPlaceholder}
            alt="Raquel Alonso Martínez, fisioterapeuta"
            width={340}
            height={450}
            class="bio__img"
          />
        </div>
        <div class="bio__content">
          <Badge text="Fisioterapeuta Colegiada Nº 12345" color="primary" />
          <h2 class="bio__name">Raquel Alonso Martínez</h2>
          <div class="bio__line"></div>
          <p class="bio__text">
            Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor
            incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud
            exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat.
          </p>
          <p class="bio__text">
            Sed ut perspiciatis unde omnis iste natus error sit voluptatem accusantium doloremque
            laudantium, totam rem aperiam, eaque ipsa quae ab illo inventore veritatis et quasi
            architecto beatae vitae dicta sunt explicabo.
          </p>
          <p class="bio__text">
            Nemo enim ipsam voluptatem quia voluptas sit aspernatur aut odit aut fugit, sed quia
            consequuntur magni dolores eos qui ratione sequi nesciunt neque porro quisquam.
          </p>
          <div class="bio__titulaciones">
            <p class="bio__titulaciones-title">Formación</p>
            <ul class="bio__titulaciones-list">
              {titulaciones.map((t) => (
                <li><span class="bio__check">✓</span>{t}</li>
              ))}
            </ul>
          </div>
        </div>
      </div>

      <!-- Valores -->
      <div class="valores">
        <div class="section__header">
          <SectionTitle
            title="Mi filosofía de trabajo"
            subtitle="Lorem ipsum dolor sit amet, consectetur adipiscing elit. Tres pilares guían cada tratamiento."
            centered
          />
        </div>
        <ul class="valores-list" data-reveal-stagger>
          {valores.map(({ icon, title, description }) => (
            <li class="valor-item">
              <div class="valor-item__icon" set:html={icon} />
              <div class="valor-item__content">
                <h3 class="valor-item__title">{title}</h3>
                <p class="valor-item__desc">{description}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- ── CONTACTO ──────────────────────────────────────────── -->
  <section id="contacto" class="section section--tinted">
    <div class="container">
      <div class="section__header">
        <SectionTitle title="Contacto" subtitle="Te responderemos en menos de 24 horas." centered />
      </div>
      <div class="contact-grid" data-reveal>

        <!-- Info -->
        <div class="contact-info">
          <ul class="contact-info__list">
            {contactInfo.map(({ icon, label, value, href }) => (
              <li class="contact-info__item">
                <div class="contact-info__icon" set:html={icon} />
                <div>
                  <p class="contact-info__label">{label}</p>
                  {href
                    ? <a href={href} class="contact-info__value contact-info__link">{value}</a>
                    : <p class="contact-info__value">{value}</p>
                  }
                </div>
              </li>
            ))}
          </ul>

          <div class="contact-schedule">
            <p class="contact-schedule__title">Horario</p>
            <ul class="contact-schedule__list">
              {horario.map(({ dia, horas }) => (
                <li>
                  <span>{dia}</span>
                  <span class="contact-schedule__hours">{horas}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- Redes y mapa -->
        <div class="contact-right">
          <div class="contact-map">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="contact-map__icon"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            <p class="contact-map__address">Calle del Bienestar, 42, 2ºB</p>
            <p class="contact-map__sub">28001 Madrid</p>
          </div>

          <div class="contact-social">
            <p class="contact-social__title">Contacta por</p>
            <div class="contact-social__list">
              <a href="https://wa.me/34912345678" class="contact-social__link" target="_blank" rel="noopener">
                <span class="contact-social__link-icon" set:html={svgWhatsApp} />
                <span>WhatsApp</span>
              </a>
              <a href="https://instagram.com/raquel.fisioterapia" class="contact-social__link" target="_blank" rel="noopener">
                <span class="contact-social__link-icon" set:html={svgInstagram} />
                <span>Instagram</span>
              </a>
              <a href="mailto:hola@raquel-fisioterapia.es" class="contact-social__link">
                <span class="contact-social__link-icon" set:html={svgMail} />
                <span>hola@raquel-fisioterapia.es</span>
              </a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

<script>
  document.documentElement.classList.add('js-ready');

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -48px 0px' }
  );

  document.querySelectorAll('[data-reveal], [data-reveal-stagger]').forEach((el) => {
    observer.observe(el);
  });
</script>
</BaseLayout>

<style>
  /* ── Hero entrance ── */
  @keyframes hero-fade-up {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: none; }
  }
  @keyframes hero-scale-in {
    from { opacity: 0; transform: scale(1.04); }
    to   { opacity: 1; transform: none; }
  }
  .hero__content  { animation: hero-fade-up  650ms var(--ease-out-expo)  80ms both; }
  .hero__img-wrap { animation: hero-scale-in 800ms var(--ease-out-expo) 320ms both; }

  /* ── Scroll reveals ── */
  .js-ready [data-reveal] {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 650ms var(--ease-out-expo), transform 650ms var(--ease-out-expo);
  }
  .js-ready [data-reveal].is-visible { opacity: 1; transform: none; }

  .js-ready [data-reveal-stagger] > * {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 500ms var(--ease-out-expo), transform 500ms var(--ease-out-expo);
  }
  .js-ready [data-reveal-stagger].is-visible > * { opacity: 1; transform: none; }
  .js-ready [data-reveal-stagger].is-visible > *:nth-child(1) { transition-delay:   0ms; }
  .js-ready [data-reveal-stagger].is-visible > *:nth-child(2) { transition-delay:  80ms; }
  .js-ready [data-reveal-stagger].is-visible > *:nth-child(3) { transition-delay: 160ms; }
  .js-ready [data-reveal-stagger].is-visible > *:nth-child(4) { transition-delay: 240ms; }

  /* ── Layout ── */
  .container {
    max-width: var(--max-width);
    margin-inline: auto;
    padding-inline: 1.5rem;
  }
  .section        { padding-block: 5rem; }
  .section--white  { background-color: white; }
  .section--tinted { background-color: var(--color-primary-5); }
  .section__header { margin-bottom: 3rem; }

  /* ── HERO ── */
  .hero {
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
  }
  .hero__inner {
    max-width: var(--max-width);
    margin-inline: auto;
    padding: 6rem 1.5rem 8rem;
    display: grid;
    gap: 3rem;
    align-items: center;
  }
  .hero__content { color: white; text-align: center; }
  .hero__pill {
    display: inline-block;
    margin-bottom: 1.25rem;
    padding: 0.25rem 0.875rem;
    border: 1px solid var(--white-70);
    border-radius: 9999px;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--white-90);
  }
  .hero__title {
    font-size: clamp(2.25rem, 6vw, 3.75rem);
    font-weight: 700;
    line-height: 1.15;
    text-wrap: balance;
  }
  .hero__desc {
    margin-top: 1.5rem;
    font-size: 1.125rem;
    line-height: 1.75;
    color: var(--white-80);
  }
  .hero__cta {
    margin-top: 2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
  }
  .hero__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 11rem;
    padding-block: 1rem;
    font-size: 1rem;
    font-weight: 600;
    border-radius: var(--radius-btn);
    transition: background-color 0.15s, color 0.15s, transform 0.2s var(--ease-out-quint);
  }
  .hero__btn:hover  { transform: translateY(-2px); }
  .hero__btn:active { transform: scale(0.97); }
  .hero__btn--outline {
    border: 2px solid white;
    color: white;
  }
  .hero__btn--outline:hover { background-color: white; color: var(--color-primary); }
  .hero__btn--solid {
    background-color: white;
    color: var(--color-primary);
  }
  .hero__btn--solid:hover { background-color: var(--white-90); }

  .hero__img-wrap {
    display: flex;
    justify-content: center;
  }
  .hero__img {
    width: 16rem;
    height: auto;
    border-radius: 1rem;
    box-shadow: var(--shadow-2xl);
  }
  .hero__wave {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
  }

  @media (min-width: 768px) {
    .hero__inner      { grid-template-columns: 1fr 1fr; padding-bottom: 10rem; }
    .hero__content    { text-align: left; }
    .hero__cta        { justify-content: flex-start; }
    .hero__img        { width: 20rem; }
  }

  /* ── SERVICIOS ── */
  .services-grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 640px)  { .services-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .services-grid { grid-template-columns: repeat(4, 1fr); } }

  /* ── BIO ── */
  .bio-grid {
    display: grid;
    gap: 3rem;
    align-items: start;
  }
  @media (min-width: 768px) { .bio-grid { grid-template-columns: 1fr 1fr; } }

  .bio__img-wrap { display: flex; justify-content: center; }
  .bio__img { width: 18rem; height: auto; border-radius: 1rem; box-shadow: var(--shadow-lg); }
  @media (min-width: 768px) { .bio__img { width: 20rem; } }

  .bio__name {
    font-size: clamp(1.875rem, 4vw, 2.25rem);
    font-weight: 700;
    color: var(--color-text);
    margin-top: 1rem;
  }
  .bio__line {
    width: 4rem; height: 4px;
    background-color: var(--color-accent);
    border-radius: 9999px;
    margin-top: 0.5rem;
  }
  .bio__text { margin-top: 1rem; line-height: 1.75; color: var(--color-text-70); }

  .bio__titulaciones       { margin-top: 2rem; }
  .bio__titulaciones-title { font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-40); margin-bottom: 0.75rem; }
  .bio__titulaciones-list  { display: flex; flex-direction: column; gap: 0.5rem; }
  .bio__titulaciones-list li { display: flex; align-items: flex-start; gap: 0.5rem; font-size: 0.875rem; color: var(--color-text-70); }
  .bio__check { color: var(--color-accent); margin-top: 0.125rem; flex-shrink: 0; }

  /* ── VALORES ── */
  .valores { margin-top: 5rem; }

  .valores-list { display: flex; flex-direction: column; }

  .valor-item {
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
    padding: 2rem 0;
    border-bottom: 1px solid var(--color-primary-10);
  }
  .valor-item:last-child { border-bottom: none; }

  .valor-item__icon {
    width: 3.5rem; height: 3.5rem; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    border-radius: 9999px;
    background-color: var(--color-accent-10);
  }
  .valor-item__icon svg { width: 1.5rem; height: 1.5rem; stroke: var(--color-accent); }

  .valor-item__title {
    font-size: 1.125rem; font-weight: 700;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }
  .valor-item__desc {

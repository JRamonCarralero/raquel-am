---
import BaseLayout from '@layouts/BaseLayout.astro';
import Button from '@components/ui/Button.astro';
import SectionTitle from '@components/ui/SectionTitle.astro';
import ServiceCard from '@components/ui/ServiceCard.astro';
import Badge from '@components/ui/Badge.astro';
import { Image } from 'astro:assets';
import fotoPlaceholder from '../assets/placeholder-foto.svg';

const services = [
  {
    icon: '🤲',
    title: 'Fisioterapia Manual',
    description: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Técnicas manuales para aliviar el dolor y recuperar la movilidad articular.',
    badge: 'Más solicitado',
  },
  {
    icon: '🏃',
    title: 'Fisioterapia Deportiva',
    description: 'Tratamiento y prevención de lesiones deportivas. Lorem ipsum dolor sit amet, consectetur adipiscing elit ut aliquam.',
    badge: 'Deportistas',
  },
  {
    icon: '🧘',
    title: 'Pilates Terapéutico',
    description: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Ejercicio terapéutico para mejorar la postura y el control motor.',
    badge: 'Grupal / Individual',
  },
  {
    icon: '🧠',
    title: 'Neurorehabilitación',
    description: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Recuperación funcional tras lesiones neurológicas.',
    badge: 'Especializado',
  },
];

const valores = [
  {
    icon: '👂',
    title: 'Escucha activa',
    description: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Cada paciente tiene una historia única que merece ser escuchada.',
  },
  {
    icon: '🎯',
    title: 'Tratamiento personalizado',
    description: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. No existen protocolos genéricos, solo planes adaptados a ti.',
  },
  {
    icon: '🔬',
    title: 'Evidencia científica',
    description: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Técnicas respaldadas por la investigación y la práctica clínica.',
  },
];

const titulaciones = [
  'Graduada en Fisioterapia — Universidad Complutense de Madrid',
  'Máster en Fisioterapia Deportiva — UCAM Murcia',
  'Especialista en Fisioterapia Neurológica — Bobath',
  'Certificada en Pilates Terapéutico — Stott Pilates',
  'Colegiada por el Colegio Profesional de Fisioterapeutas de Madrid — Nº 12345',
];

const contactInfo = [
  { icon: '📍', label: 'Dirección', value: 'Calle del Bienestar, 42, 2ºB\n28001 Madrid' },
  { icon: '📞', label: 'Teléfono', value: '+34 912 345 678' },
  { icon: '✉️', label: 'Email', value: 'hola@raquel-fisioterapia.es' },
];

const horario = [
  { dia: 'Lunes – Viernes', horas: '9:00 – 20:00' },
  { dia: 'Sábados',         horas: '10:00 – 14:00' },
  { dia: 'Domingos',        horas: 'Cerrado' },
];
---

<BaseLayout
  title="Fisioterapia en Madrid"
  description="Raquel Alonso Martínez, fisioterapeuta en Madrid. Tratamientos personalizados de fisioterapia manual, deportiva, pilates terapéutico y neurorehabilitación."
>

  <!-- ── INICIO ────────────────────────────────────────────── -->
  <section id="inicio" class="hero">
    <div class="hero__inner">
      <div class="hero__content">
        <p class="hero__eyebrow">Fisioterapia · Madrid</p>
        <h1 class="hero__title">Tu bienestar,<br />en buenas manos</h1>
        <p class="hero__desc">
          Lorem ipsum dolor sit amet, consectetur adipiscing elit. Ut enim ad minim veniam,
          quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat.
        </p>
        <div class="hero__cta">
          <a href="#servicios" class="hero__btn hero__btn--outline">Ver servicios</a>
          <a href="#contacto"  class="hero__btn hero__btn--solid">Contacto</a>
        </div>
      </div>
      <div class="hero__img-wrap">
        <Image
          src={fotoPlaceholder}
          alt="Raquel Alonso Martínez, fisioterapeuta"
          width={300}
          height={400}
          class="hero__img"
        />
      </div>
    </div>
    <div class="hero__wave" aria-hidden="true">
      <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0 60L1440 60L1440 20C1200 60 960 0 720 20C480 40 240 0 0 20Z" fill="#F8F9FA"/>
      </svg>
    </div>
  </section>

  <!-- ── SERVICIOS ─────────────────────────────────────────── -->
  <section id="servicios" class="section">
    <div class="container">
      <div class="section__header">
        <SectionTitle
          title="Nuestros Servicios"
          subtitle="Un enfoque integral para cada paciente, combinando las técnicas más avanzadas con un trato cercano y personalizado."
          centered
        />
      </div>
      <div class="services-grid">
        {services.map((s) => <ServiceCard {...s} />)}
      </div>
    </div>
  </section>

  <!-- ── QUIÉN SOY ─────────────────────────────────────────── -->
  <section id="quien-soy" class="section section--white">
    <div class="container">
      <div class="bio-grid">
        <div class="bio__img-wrap">
          <Image
            src={fotoPlaceholder}
            alt="Raquel Alonso Martínez, fisioterapeuta"
            width={340}
            height={450}
            class="bio__img"
          />
        </div>
        <div class="bio__content">
          <Badge text="Fisioterapeuta Colegiada Nº 12345" color="primary" />
          <h2 class="bio__name">Raquel Alonso Martínez</h2>
          <div class="bio__line"></div>
          <p class="bio__text">
            Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor
            incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud
            exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat.
          </p>
          <p class="bio__text">
            Sed ut perspiciatis unde omnis iste natus error sit voluptatem accusantium doloremque
            laudantium, totam rem aperiam, eaque ipsa quae ab illo inventore veritatis et quasi
            architecto beatae vitae dicta sunt explicabo.
          </p>
          <p class="bio__text">
            Nemo enim ipsam voluptatem quia voluptas sit aspernatur aut odit aut fugit, sed quia
            consequuntur magni dolores eos qui ratione sequi nesciunt neque porro quisquam.
          </p>
          <div class="bio__titulaciones">
            <p class="bio__titulaciones-title">Formación</p>
            <ul class="bio__titulaciones-list">
              {titulaciones.map((t) => (
                <li><span class="bio__check">✓</span>{t}</li>
              ))}
            </ul>
          </div>
        </div>
      </div>

      <!-- Valores -->
      <div class="valores">
        <div class="section__header">
          <SectionTitle
            title="Mi filosofía de trabajo"
            subtitle="Lorem ipsum dolor sit amet, consectetur adipiscing elit. Tres pilares guían cada tratamiento."
            centered
          />
        </div>
        <div class="valores-grid">
          {valores.map(({ icon, title, description }) => (
            <div class="valor-card">
              <div class="valor-card__icon">{icon}</div>
              <h3>{title}</h3>
              <p>{description}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ── CONTACTO ──────────────────────────────────────────── -->
  <section id="contacto" class="section section--tinted">
    <div class="container">
      <div class="section__header">
        <SectionTitle title="Contacto" subtitle="Te responderemos en menos de 24 horas." centered />
      </div>
      <div class="contact-grid">

        <!-- Info -->
        <div class="contact-info">
          <ul class="contact-info__list">
            {contactInfo.map(({ icon, label, value }) => (
              <li class="contact-info__item">
                <div class="contact-info__icon">{icon}</div>
                <div>
                  <p class="contact-info__label">{label}</p>
                  <p class="contact-info__value">{value}</p>
                </div>
              </li>
            ))}
          </ul>

          <div class="contact-schedule">
            <p class="contact-schedule__title">Horario</p>
            <ul class="contact-schedule__list">
              {horario.map(({ dia, horas }) => (
                <li>
                  <span>{dia}</span>
                  <span class="contact-schedule__hours">{horas}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="contact-map">
            <span class="contact-map__icon">🗺️</span>
            <p>Mapa de ubicación</p>
            <p class="contact-map__sub">Calle del Bienestar, 42 — Madrid</p>
          </div>
        </div>

        <!-- Formulario -->
        <div class="contact-form-wrap">
          <form class="contact-form" action="#" method="POST">
            <div class="form-row">
              <div class="form-group">
                <label for="nombre">Nombre <span class="form-required">*</span></label>
                <input type="text" id="nombre" name="nombre" required placeholder="Tu nombre" />
              </div>
              <div class="form-group">
                <label for="email">Email <span class="form-required">*</span></label>
                <input type="email" id="email" name="email" required placeholder="tu@email.com" />
              </div>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label for="telefono">Teléfono</label>
                <input type="tel" id="telefono" name="telefono" placeholder="+34 6XX XXX XXX" />
              </div>
              <div class="form-group">
                <label for="asunto">Asunto</label>
                <select id="asunto" name="asunto">
                  <option value="">Selecciona una opción</option>
                  <option value="primera-visita">Primera visita</option>
                  <option value="revision">Revisión</option>
                  <option value="informacion">Solicitar información</option>
                  <option value="otro">Otro</option>
                </select>
              </div>
            </div>
            <div class="form-group">
              <label for="mensaje">Mensaje <span class="form-required">*</span></label>
              <textarea id="mensaje" name="mensaje" required rows="5" placeholder="Cuéntanos qué podemos hacer por ti..."></textarea>
            </div>
            <Button type="submit" variant="primary" size="lg" fullWidth>Enviar mensaje</Button>
            <p class="form-note">* Campos obligatorios. Tus datos se tratarán conforme a nuestra política de privacidad.</p>
          </form>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Layout ── */
  .container {
    max-width: var(--max-width);
    margin-inline: auto;
    padding-inline: 1.5rem;
  }
  .section        { padding-block: 5rem; }
  .section--white  { background-color: white; }
  .section--tinted { background-color: var(--color-primary-5); }
  .section__header { margin-bottom: 3rem; }

  /* ── HERO ── */
  .hero {
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
  }
  .hero__inner {
    max-width: var(--max-width);
    margin-inline: auto;
    padding: 6rem 1.5rem 8rem;
    display: grid;
    gap: 3rem;
    align-items: center;
  }
  .hero__content { color: white; text-align: center; }
  .hero__eyebrow {
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--white-70);
    margin-bottom: 0.75rem;
  }
  .hero__title {
    font-size: clamp(2.25rem, 6vw, 3.75rem);
    font-weight: 700;
    line-height: 1.15;
  }
  .hero__desc {
    margin-top: 1.5rem;
    font-size: 1.125rem;
    line-height: 1.75;
    color: var(--white-80);
  }
  .hero__cta {
    margin-top: 2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
  }
  .hero__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 11rem;
    padding-block: 1rem;
    font-size: 1rem;
    font-weight: 600;
    border-radius: var(--radius-btn);
    transition: background-color 0.15s, color 0.15s;
  }
  .hero__btn--outline {
    border: 2px solid white;
    color: white;
  }
  .hero__btn--outline:hover { background-color: white; color: var(--color-primary); }
  .hero__btn--solid {
    background-color: white;
    color: var(--color-primary);
  }
  .hero__btn--solid:hover { background-color: var(--white-90); }

  .hero__img-wrap {
    display: flex;
    justify-content: center;
  }
  .hero__img {
    width: 16rem;
    height: auto;
    border-radius: 1rem;
    box-shadow: var(--shadow-2xl);
  }
  .hero__wave {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
  }

  @media (min-width: 768px) {
    .hero__inner      { grid-template-columns: 1fr 1fr; padding-bottom: 10rem; }
    .hero__content    { text-align: left; }
    .hero__cta        { justify-content: flex-start; }
    .hero__img        { width: 20rem; }
  }

  /* ── SERVICIOS ── */
  .services-grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 640px)  { .services-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .services-grid { grid-template-columns: repeat(4, 1fr); } }

  /* ── BIO ── */
  .bio-grid {
    display: grid;
    gap: 3rem;
    align-items: start;
  }
  @media (min-width: 768px) { .bio-grid { grid-template-columns: 1fr 1fr; } }

  .bio__img-wrap { display: flex; justify-content: center; }
  .bio__img { width: 18rem; height: auto; border-radius: 1rem; box-shadow: var(--shadow-lg); }
  @media (min-width: 768px) { .bio__img { width: 20rem; } }

  .bio__name {
    font-size: clamp(1.875rem, 4vw, 2.25rem);
    font-weight: 700;
    color: var(--color-text);
    margin-top: 1rem;
  }
  .bio__line {
    width: 4rem; height: 4px;
    background-color: var(--color-accent);
    border-radius: 9999px;
    margin-top: 0.5rem;
  }
  .bio__text { margin-top: 1rem; line-height: 1.75; color: var(--color-text-70); }

  .bio__titulaciones       { margin-top: 2rem; }
  .bio__titulaciones-title { font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-40); margin-bottom: 0.75rem; }
  .bio__titulaciones-list  { display: flex; flex-direction: column; gap: 0.5rem; }
  .bio__titulaciones-list li { display: flex; align-items: flex-start; gap: 0.5rem; font-size: 0.875rem; color: var(--color-text-70); }
  .bio__check { color: var(--color-accent); margin-top: 0.125rem; flex-shrink: 0; }

  /* ── VALORES ── */
  .valores { margin-top: 5rem; }
  .valores-grid { display: grid; gap: 1.5rem; }
  @media (min-width: 768px) { .valores-grid { grid-template-columns: repeat(3, 1fr); } }

  .valor-card {
    background: var(--color-bg);
    border-radius: var(--radius-card);
    padding: 2rem;
    box-shadow: var(--shadow-sm);
  }
  .valor-card__icon {
    width: 3.5rem; height: 3.5rem;
    display: flex; align-items: center; justify-content: center;
    border-radius: 9999px;
    background-color: var(--color-accent-10);
    font-size: 1.75rem;
    margin-bottom: 1rem;
  }
  .valor-card h3 { font-size: 1.25rem; font-weight: 700; color: var(--color-text); margin-bottom: 0.75rem; }
  .valor-card p  { font-size: 0.875rem; line-height: 1.625; color: var(--color-text-60); }

  /* ── CONTACTO ── */
  .contact-grid { display: grid; gap: 3rem; }
  @media (min-width: 768px) { .contact-grid { grid-template-columns: 1fr 1fr; } }

  .contact-info__list  { display: flex; flex-direction: column; gap: 1.5rem; }
  .contact-info__item  { display: flex; align-items: flex-start; gap: 1rem; }
  .contact-info__icon  {
    width: 2.5rem; height: 2.5rem; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    border-radius: 9999px;
    background-color: var(--color-accent-10);
    font-size: 1.25rem;
  }
  .contact-info__label { font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-40); }
  .contact-info__value { font-size: 0.875rem; color: var(--color-text-80); white-space: pre-line; margin-top: 0.25rem; }

  .contact-schedule {
    margin-top: 2rem;
    background: white;
    border-radius: var(--radius-card);
    padding: 1.5rem;
    box-shadow: var(--shadow-sm);
  }
  .contact-schedule__title { font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-40); margin-bottom: 1rem; }
  .contact-schedule__list  { display: flex; flex-direction: column; gap: 0.5rem; }
  .contact-schedule__list li { display: flex; justify-content: space-between; font-size: 0.875rem; color: var(--color-text-70); }
  .contact-schedule__hours { font-weight: 500; color: var(--color-text); }

  .contact-map {
    margin-top: 2rem;
    height: 12rem;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    border-radius: var(--radius-card);
    border: 2px dashed var(--color-primary-20);
    background: white;
    color: var(--color-text-40);
    text-align: center;
  }
  .contact-map__icon { font-size: 2.5rem; }
  .contact-map p     { margin-top: 0.5rem; font-size: 0.875rem; }
  .contact-map__sub  { font-size: 0.75rem; }

  .contact-form-wrap {
    background: white;
    border-radius: var(--radius-card);
    padding: 2rem;
    box-shadow: var(--shadow-sm);
  }
  .contact-form { display: flex; flex-direction: column; gap: 1.25rem; }

  .form-row { display: grid; gap: 1.25rem; }
  @media (min-width: 640px) { .form-row { grid-template-columns: 1fr 1fr; } }

  .form-group { display: flex; flex-direction: column; gap: 0.375rem; }
  .form-group label { font-size: 0.875rem; font-weight: 500; color: var(--color-text-70); }
  .form-required { color: #f87171; }

  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    font-family: var(--font-sans);
    color: var(--color-text);
    border: 1px solid #e5e7eb;
    border-radius: 0.5rem;
    outline: none;
    transition: border-color 0.15s, box-shadow 0.15s;
    background: white;
  }
  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px var(--color-accent-20);
  }
  .form-group textarea { resize: none; }

  .form-note { font-size: 0.75rem; color: var(--color-text-40); text-align: center; }
</style>
